<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>

  <!-- ── 任务标识 ─────────────────────────────────────── -->
  <key>Label</key>
  <string>com.mengxi.gmail-digest</string>

  <!-- ── 执行命令 ─────────────────────────────────────── -->
  <key>ProgramArguments</key>
  <array>
    <string>/Users/hulimofaqiu/miniconda3/bin/python3</string>
    <string>/Users/hulimofaqiu/mengxi-first-ai-project/scripts/auto_gmail_digest.py</string>
  </array>

  <!-- ── 触发方式：每天早晨 8:00 执行 ────────────────── -->
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>8</integer>
    <key>Minute</key>
    <integer>0</integer>
  </dict>

  <!-- ── 工作目录 ─────────────────────────────────────── -->
  <key>WorkingDirectory</key>
  <string>/Users/hulimofaqiu/mengxi-first-ai-project</string>

  <!-- ── 日志输出 ─────────────────────────────────────── -->
  <key>StandardOutPath</key>
  <string>/Users/hulimofaqiu/mengxi-first-ai-project/logs/gmail-digest.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/hulimofaqiu/mengxi-first-ai-project/logs/gmail-digest-error.log</string>

  <!-- ── 环境变量 ─────────────────────────────────────── -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/Users/hulimofaqiu/miniconda3/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>HOME</key>
    <string>/Users/hulimofaqiu</string>
    <key>PYTHONPATH</key>
    <string>/Users/hulimofaqiu/mengxi-first-ai-project/scripts</string>
  </dict>

  <!-- ── 开机后首次加载时也执行一次 ──────────────────── -->
  <key>RunAtLoad</key>
  <false/>

  <key>KeepAlive</key>
  <false/>

</dict>
</plist>
